# Frontend Development Dockerfile for Local Testing
FROM node:21-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY . .

# Build environment variables
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL:-http://127.0.0.1:8080/api}
ENV VITE_WS_BASE_URL=${VITE_WS_BASE_URL:-http://127.0.0.1:8080}

# Expose development server port
EXPOSE 5173

# Start development server with HMR enabled
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
